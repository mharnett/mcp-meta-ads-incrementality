{
  "name": "mcp-meta-ads-incrementality",
  "version": "0.1.0",
  "description": "MCP server for Meta Marketing API focused on incrementality reporting. Surfaces Meta's incremental conversion attribution alongside default 7d-click/1d-view and dda windows so agencies can see the gap between reported and incremental performance.",
  "main": "dist/index.js",
  "bin": {
    "mcp-meta-ads-incrementality": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "meta-ads",
    "facebook-ads",
    "marketing-api",
    "incrementality",
    "attribution",
    "advertising",
    "agency"
  ],
  "author": "drak-marketing",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "facebook-nodejs-business-sdk": "^24.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/facebook-nodejs-business-sdk": "^23.0.0",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
